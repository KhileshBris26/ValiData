# ==========================================
# ValiData (Robin) — Environment Variables
# ==========================================
# Copy this file to the project ROOT as ".env" and fill in real values.
# NEVER commit the actual .env file to git (it is in .gitignore).
#
# Usage:
#   cp config/environments/.env.example .env
#   # then edit .env with your real credentials

# ==========================================
# SNOWFLAKE CREDENTIALS
# ==========================================
SNOWFLAKE_ACCOUNT=your-account-locator          # e.g. CEDKVOT-PHB81098
SNOWFLAKE_USER=your-snowflake-username
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=your-warehouse-name         # e.g. SMALL_WH
SNOWFLAKE_DATABASE=your-database-name           # e.g. UNICORN
SNOWFLAKE_SCHEMA=your-schema-name               # e.g. DEV

# ==========================================
# DATABRICKS CREDENTIALS
# ==========================================
DATABRICKS_SERVER_HOSTNAME=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_ACCESS_TOKEN=your-databricks-personal-access-token

# ==========================================
# EMAIL / OTP CREDENTIALS (SMTP)
# ==========================================
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password           # Use an App Password, not your main password
