# ============================================================
# ValiData (.env) — Environment Variable Template
# ============================================================
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
#
# NEVER commit the real `.env` file. It is in .gitignore.
# ============================================================

# ==========================================
# SNOWFLAKE CREDENTIALS
# ==========================================
# Get these from your Snowflake account or team lead.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=SMALL_WH
SNOWFLAKE_DATABASE=UNICORN
SNOWFLAKE_SCHEMA=DEV

# ==========================================
# DATABRICKS CREDENTIALS (Optional)
# ==========================================
# Only needed if you work with Databricks connectors.
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_ACCESS_TOKEN=

# ==========================================
# EMAIL / OTP (Optional for local dev)
# ==========================================
# If not set, OTPs will print to the console instead of sending real emails.
# Production values are set on Render — ask the team lead.
RESEND_API_KEY=
RESEND_FROM_EMAIL=ValiData <onboarding@resend.dev>

# Legacy SMTP (not used in production — Resend is primary)
SMTP_USER=
SMTP_PASSWORD=

# ==========================================
# DATABASE (Production Only — Do NOT set locally)
# ==========================================
# When set, the backend uses PostgreSQL (Neon) instead of local SQLite.
# This is configured on Render automatically.
# DATABASE_URL=postgresql://user:pass@host/dbname
